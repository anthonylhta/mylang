// FizzBuzz from 1 to 20.
// Exercises: while loops, if/else chains, modulo, comparisons, assignment,
// and printing both strings and numbers.

let i = 1;
while (i <= 20) {
  if (i % 15 == 0) {
    print "FizzBuzz";
  } else if (i % 3 == 0) {
    print "Fizz";
  } else if (i % 5 == 0) {
    print "Buzz";
  } else {
    print i;
  }
  i = i + 1;
}
