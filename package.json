{
  "name": "mylang",
  "version": "0.0.1",
  "description": "A tiny tree-walking interpreter for a small scripting language, built lexer -> parser -> AST -> evaluator.",
  "type": "module",
  "bin": {
    "mylang": "src/index.ts"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "repl": "tsx src/index.ts",
    "fizzbuzz": "tsx src/index.ts examples/fizzbuzz.mylang",
    "fib": "tsx src/index.ts examples/fib.mylang",
    "closures": "tsx src/index.ts examples/closures.mylang",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "interpreter",
    "language",
    "lexer",
    "parser",
    "tree-walking"
  ],
  "author": "Anthony Ta",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
