{
  "name": "mylang",
  "version": "0.0.1",
  "description": "A tiny tree-walking interpreter for a small scripting language, built lexer -> parser -> AST -> evaluator.",
  "type": "module",
  "bin": {
    "mylang": "src/index.ts"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "repl": "tsx src/index.ts",
    "fizzbuzz": "tsx src/index.ts examples/fizzbuzz.mylang",
    "fib": "tsx src/index.ts examples/fib.mylang",
    "closures": "tsx src/index.ts examples/closures.mylang",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "build": "tsc -p tsconfig.build.json",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "interpreter",
    "language",
    "lexer",
    "parser",
    "tree-walking"
  ],
  "author": "Anthony Ta",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
